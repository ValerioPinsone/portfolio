---
import type { Lang } from '../i18n/types'

interface Props {
  title?:       string
  description?: string
  lang?:        Lang
}

// Update SITE_URL once deployed
const SITE_URL = 'https://valeriopinsone.dev'

const { title, description, lang = 'en' } = Astro.props

const titles: Record<Lang, string> = {
  en: 'Valerio Pinsone — Frontend Developer | Angular, React & Astro',
  it: 'Valerio Pinsone — Frontend Developer | Sviluppo Web & Applicazioni',
}

const descriptions: Record<Lang, string> = {
  en: 'Frontend Developer based in Rome, Italy. Expert in Angular, React and Astro. 7+ years building scalable web applications, modern UIs and enterprise solutions. Available for new projects.',
  it: 'Frontend Developer con sede a Roma. Specializzato in Angular, React e Astro. 7+ anni di esperienza nello sviluppo di siti web, applicazioni web e interfacce moderne. Disponibile per nuovi progetti.',
}

const keywords: Record<Lang, string> = {
  en: 'Valerio Pinsone, Frontend Developer, Web Developer, Angular Developer, React Developer, Astro, TypeScript, JavaScript, Web Applications, UI Developer, Software Engineer, Rome Italy, Portfolio, Next.js',
  it: 'Valerio Pinsone, Frontend Developer, Sviluppatore Frontend, Sviluppo Siti Web, Applicazioni Web, Angular, React, Astro, TypeScript, JavaScript, Sviluppatore Web Roma, Portfolio, Next.js, Sviluppo Software',
}

const resolvedTitle = title ?? titles[lang]
const resolvedDesc  = description ?? descriptions[lang]
const canonicalUrl  = lang === 'en' ? SITE_URL : `${SITE_URL}/it`
const alternateEn   = SITE_URL
const alternateIt   = `${SITE_URL}/it`
const ogLocale      = lang === 'en' ? 'en_US' : 'it_IT'
const ogLocaleAlt   = lang === 'en' ? 'it_IT' : 'en_US'

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Valerio Pinsone',
  jobTitle: 'Frontend Developer',
  description: descriptions.en,
  email: 'valerio.pinsone@gmail.com',
  url: SITE_URL,
  sameAs: [
    'https://www.linkedin.com/in/valeriopinsone/',
    'https://github.com/valeriopinsone',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Rome',
    addressRegion: 'Lazio',
    addressCountry: 'IT',
  },
  knowsLanguage: ['Italian', 'English'],
  knowsAbout: [
    'Angular', 'React', 'Astro', 'Next.js', 'TypeScript', 'JavaScript',
    'Frontend Development', 'Web Development', 'Web Applications',
    'Tailwind CSS', 'UI Design',
  ],
})
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDesc} />
    <meta name="keywords"    content={keywords[lang]} />
    <meta name="author"      content="Valerio Pinsone" />
    <meta name="robots"      content="index, follow" />
    <meta name="theme-color" content="#09090b" />
    <link rel="canonical"    href={canonicalUrl} />

    <!-- hreflang for bilingual indexing -->
    <link rel="alternate" hreflang="en"       href={alternateEn} />
    <link rel="alternate" hreflang="it"       href={alternateIt} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />

    <!-- Open Graph -->
    <meta property="og:type"              content="profile" />
    <meta property="og:title"             content={resolvedTitle} />
    <meta property="og:description"       content={resolvedDesc} />
    <meta property="og:url"               content={canonicalUrl} />
    <meta property="og:site_name"         content="Valerio Pinsone — Portfolio" />
    <meta property="og:locale"            content={ogLocale} />
    <meta property="og:locale:alternate"  content={ogLocaleAlt} />
    <meta property="profile:first_name"   content="Valerio" />
    <meta property="profile:last_name"    content="Pinsone" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDesc} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />

    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased overflow-x-hidden">
    <!-- Scroll progress bar -->
    <div
      id="scroll-progress"
      class="fixed top-0 left-0 h-[2px] w-full origin-left scale-x-0 z-[60]"
      style="background: linear-gradient(90deg, #00e5ff, #a855f7);"
    ></div>

    <slot />
  </body>
</html>

<style>
  html, body { margin: 0; width: 100%; scroll-behavior: smooth; }
</style>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  gsap.to('#scroll-progress', {
    scaleX: 1,
    ease: 'none',
    scrollTrigger: { start: 0, end: 'max', scrub: true },
  })

  gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 48 },
      { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%', once: true } }
    )
  })

  gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((parent) => {
    gsap.fromTo(Array.from(parent.children),
      { opacity: 0, y: 32 },
      { opacity: 1, y: 0, stagger: 0.1, duration: 0.6, ease: 'power2.out',
        scrollTrigger: { trigger: parent, start: 'top 85%', once: true } }
    )
  })

  // Parallax solo su desktop (md+): su mobile gli elementi sono in colonna
  // e il movimento li farebbe sovrapporre
  gsap.matchMedia().add('(min-width: 768px)', () => {
    gsap.utils.toArray<HTMLElement>('[data-parallax]').forEach((el) => {
      const yPercent = el.dataset.parallax === 'slow' ? 25 : -25
      gsap.to(el, {
        yPercent, ease: 'none',
        scrollTrigger: {
          trigger: el.closest('section') ?? el,
          start: 'top bottom', end: 'bottom top', scrub: true,
        },
      })
    })
  })

  gsap.utils.toArray<HTMLElement>('[data-count]').forEach((el) => {
    const target = parseInt(el.dataset.count ?? '0')
    const suffix = el.dataset.suffix ?? ''
    ScrollTrigger.create({
      trigger: el, start: 'top 88%', once: true,
      onEnter: () => {
        gsap.to({ val: 0 }, {
          val: target, duration: 1.6, ease: 'power2.out',
          onUpdate(this: gsap.core.Tween) {
            el.textContent = Math.round((this.targets()[0] as { val: number }).val) + suffix
          },
        })
      },
    })
  })
</script>
