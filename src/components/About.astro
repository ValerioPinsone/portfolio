---
import type { AboutT } from '../i18n/types'

interface Props { t: AboutT }
const { t } = Astro.props
const { stats, profile } = t
---

<section id="about" class="py-24 px-6 max-w-5xl mx-auto overflow-hidden">
  <div class="flex items-center gap-4 mb-12" data-reveal>
    <span class="font-mono text-cyan-400 text-sm opacity-60">{t.sectionNum}</span>
    <h2 class="text-3xl font-bold">{t.title}</h2>
    <div class="flex-1 h-[1px] bg-gradient-to-r from-cyan-400/40 to-transparent"></div>
  </div>

  <div class="grid md:grid-cols-2 gap-12 items-start">
    <!-- Left: text + stats -->
    <div data-parallax="slow">
      <div class="space-y-4 text-zinc-400 leading-relaxed mb-10">
        <p>{t.p1}</p>
        <p>{t.p2}</p>
        <p>{t.p3}</p>
      </div>

      <div class="grid grid-cols-3 gap-4 pt-8 border-t border-zinc-800">
        <div>
          <div
            class="text-3xl font-bold text-cyan-400 neon-text font-mono"
            data-count={stats.years.count}
            data-suffix={stats.years.suffix}
          >0{stats.years.suffix}</div>
          <div class="text-xs text-zinc-500 mt-1 font-mono">{stats.years.label}</div>
        </div>
        <div>
          <div
            class="text-3xl font-bold text-cyan-400 neon-text font-mono"
            data-count={stats.projects.count}
            data-suffix={stats.projects.suffix}
          >0{stats.projects.suffix}</div>
          <div class="text-xs text-zinc-500 mt-1 font-mono">{stats.projects.label}</div>
        </div>
        <div>
          <div
            class="text-3xl font-bold text-cyan-400 neon-text font-mono"
            data-count={stats.stack.count}
          >0</div>
          <div class="text-xs text-zinc-500 mt-1 font-mono">{stats.stack.label}</div>
        </div>
      </div>
    </div>

    <!-- Right: JSON card -->
    <div
      class="border border-zinc-800 rounded bg-zinc-900/60 backdrop-blur overflow-hidden"
      data-parallax="fast"
    >
      <div class="flex items-center gap-2 px-4 py-3 border-b border-zinc-800 bg-zinc-900">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500/70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-green-500/70"></span>
        <span class="font-mono text-xs text-zinc-500 ml-2">{profile.filename}</span>
      </div>

      <div class="p-6 font-mono text-sm space-y-3">
        <div class="flex gap-3 flex-wrap">
          <span class="text-purple-400">{profile.locationLabel}</span>
          <span class="text-zinc-600">:</span>
          <span class="text-cyan-300">{profile.locationValue}</span>
        </div>
        <div class="flex gap-3 flex-wrap">
          <span class="text-purple-400">{profile.availLabel}</span>
          <span class="text-zinc-600">:</span>
          <span class="text-green-400">{profile.availValue}</span>
        </div>
        <div class="flex gap-3 flex-wrap">
          <span class="text-purple-400">{profile.focusLabel}</span>
          <span class="text-zinc-600">:</span>
          <span class="text-cyan-300">{profile.focusValue}</span>
        </div>
        <div class="flex gap-3 flex-wrap">
          <span class="text-purple-400">{profile.emailLabel}</span>
          <span class="text-zinc-600">:</span>
          <a
            href="mailto:valerio.pinsone@gmail.com"
            class="text-cyan-400 hover:text-cyan-300 transition-colors break-all"
          >"valerio.pinsone@gmail.com"</a>
        </div>
      </div>
    </div>
  </div>
</section>
