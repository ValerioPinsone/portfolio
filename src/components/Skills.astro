  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-12" data-reveal>
      <span class="font-mono text-cyan-400 text-sm opacity-60">02.</span>
      <h2 class="text-3xl font-bold">Skills</h2>
