---
import type { ContactT } from '../i18n/types'

interface Props { t: ContactT }
const { t } = Astro.props
---

<section id="contact" class="py-24 px-6 cyber-grid-bg">
  <div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-12" data-reveal>
      <span class="font-mono text-cyan-400 text-sm opacity-60">{t.sectionNum}</span>
      <h2 class="text-3xl font-bold">{t.title}</h2>
      <div class="flex-1 h-[1px] bg-gradient-to-r from-cyan-400/40 to-transparent"></div>
    </div>

    <div class="border border-zinc-800 rounded overflow-hidden" data-reveal>
      <div class="flex items-center gap-2 px-4 py-3 bg-zinc-900 border-b border-zinc-800">
        <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
        <span class="font-mono text-xs text-zinc-500 ml-3">{t.filename}</span>
      </div>

      <div class="bg-zinc-950 p-6 sm:p-8 font-mono text-sm space-y-3">
        <p class="text-zinc-500">$ <span class="text-cyan-400">whoami</span></p>
        <p class="text-zinc-300 pl-4">{t.whoami}</p>

        <p class="text-zinc-500 pt-2">$ <span class="text-cyan-400">cat contact.txt</span></p>
        <p class="text-zinc-400 pl-4">{t.line1}<br />{t.line2}</p>

        <p class="text-zinc-500 pt-2">$ <span class="text-cyan-400">send --to</span></p>
        <div class="pl-4 pt-1">
          <a
            href="mailto:valerio.pinsone@gmail.com"
            class="text-cyan-400 hover:text-cyan-300 underline underline-offset-4 decoration-cyan-400/30 hover:decoration-cyan-300 transition-colors break-all cursor-blink"
          >
            valerio.pinsone@gmail.com
          </a>
        </div>
      </div>
    </div>

    <div class="flex gap-6 mt-8 justify-center font-mono text-sm text-zinc-500" data-stagger>
      <a href="https://github.com/ValerioPinsone" target="_blank" rel="noopener" class="hover:text-cyan-400 transition-colors flex items-center gap-1">
        <span class="text-zinc-600">~/</span>{t.github}
      </a>
      <a href="https://www.linkedin.com/in/valeriopinsone" target="_blank" rel="noopener" class="hover:text-purple-400 transition-colors flex items-center gap-1">
        <span class="text-zinc-600">~/</span>{t.linkedin}
      </a>
    </div>
  </div>
</section>
