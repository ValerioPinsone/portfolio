---
import type { FooterT } from '../i18n/types'

interface Props { t: FooterT }
const { t } = Astro.props
const year = new Date().getFullYear()
---

<footer class="border-t border-zinc-800/60 py-8 px-6">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 font-mono text-xs text-zinc-600">
    <span>&copy; {year} Valerio Pinsone</span>
    <span class="text-zinc-700">{t.built}</span>
  </div>
</footer>
